# Supabase - get these from your Supabase project dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI Provider Keys (multi-provider fallback chain)
# Primary + fallback + budget: Google AI — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
# Quality fallback: Groq Llama 3.3 70B — https://console.groq.com/keys
GROQ_API_KEY=

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
